def _build_dashboard(wb: Workbook, df: pd.DataFrame, weights: dict):
    ws = wb.active
    ws.title = "Dashboard"
    ws.sheet_view.showGridLines = False

    # Tytuł
    ws.merge_cells("A1:M1")
    t = ws.cell(row=1, column=1, value="Bank · Opportunity Scoring · Dashboard")
    t.font = _f(True, 14, _WHITE); t.fill = _fill(_NAVY); t.alignment = _al()
    ws.row_dimensions[1].height = 36

    # ── Blok wag ────────────────────────────────────────────────────────────
    _title_merged(ws, 3, 1, 4, "Wagi scoringu (żółte komórki = edytowalne)", _BLUE_MID)
    _header(ws, 4, ["Składowa", "Waga", "% sumy", "Opis"], bg=_HEAD_BG, height=28)
    for r in range(4, 5):
        for c in range(1, 5):
            ws.cell(row=r, column=c).font = _f(True, 10, _BLACK)

    weight_meta = [
        ("penetracja_gap",      weights["penetracja_gap"],      "Niezagospodarowany potencjał rynkowy"),
        ("luka_konkurencyjna",  weights["luka_konkurencyjna"],   "Udział własny vs. konkurencja"),
        ("dynamika_wzrostu",    weights["dynamika_wzrostu"],     "Saldo migracji 60% + przyrost 40%"),
        ("shift_demograficzny", weights["shift_demograficzny"],  "Zmiana grupy 20-35 wg powiatu (2035)"),
    ]
    for i, (key, waga, opis) in enumerate(weight_meta, start=5):
        _w(ws, i, 1, key, align="left")
        cell_w = ws.cell(row=i, column=2, value=waga)
        cell_w.font = _f(True, 11, _INPUT); cell_w.fill = _fill(_YELLOW)
        cell_w.alignment = _al(); cell_w.border = _BRD; cell_w.number_format = "0.00"
        _w(ws, i, 3, f"=B{i}/SUM($B$5:$B$8)", fmt="0.0%")
        _w(ws, i, 4, opis, align="left")

    _w(ws, 9, 1, "Suma kontrolna wag", bold=True, bg=_HEAD_BG)
    _w(ws, 9, 2, "=SUM(B5:B8)", bold=True, fmt="0.00")
    _w(ws, 9, 3, "", border=True); _w(ws, 9, 4, "Musi wynosić 1.00", align="left",
                                       color="7F7F7F", size=9)

    # ── Parametry modelu ────────────────────────────────────────────────────
    _title_merged(ws, 11, 1, 4, "Parametry modelu", _BLUE_MID)
    _header(ws, 12, ["Parametr", "Wartość", "Opis", ""], bg=_HEAD_BG, height=24)
    params = [
        ("MAX_PENETRATION", MAX_PENETRATION, "Maks. zakładany udział klientów w populacji"),
        ("BLEND_GMINA",     BLEND_GMINA,     "Waga danych gminnych (gmina ≠ powiat)"),
        ("BLEND_POWIAT",    BLEND_POWIAT,    "Waga danych powiatowych (gmina ≠ powiat)"),
    ]
    for i, (name, val, desc) in enumerate(params, start=13):
        _w(ws, i, 1, name, align="left")
        cell_p = ws.cell(row=i, column=2, value=val)
        cell_p.font = _f(True, 11, _INPUT); cell_p.fill = _fill(_YELLOW)
        cell_p.alignment = _al(); cell_p.border = _BRD; cell_p.number_format = "0.00"
        _w(ws, i, 3, desc, align="left"); _w(ws, i, 4, "")

    # ── KPI ─────────────────────────────────────────────────────────────────
    _title_merged(ws, 3, 6, 9, "Podsumowanie", _BLUE_MID)
    kpi = [
        ("Gmin w scoringu",        len(df),                          None),
        ("Śr. Opportunity Score",  round(df["opportunity_score"].mean(), 1), None),
        ("Segment Priorytet",      int((df["segment"]=="Priorytet").sum()), "1A6B3C"),
        ("Segment Wysoki",         int((df["segment"]=="Wysoki").sum()),    "2E86AB"),
        ("Segment Średni",         int((df["segment"]=="Średni").sum()),    "F4A261"),
        ("Segment Niski",          int((df["segment"]=="Niski").sum()),     "C9453A"),
    ]
    for i, (lbl, val, color) in enumerate(kpi, start=4):
        bg  = color or _HEAD_BG
        tc  = _WHITE if color else _BLACK
        _w(ws, i, 6, lbl,  align="left",   bg=bg, color=tc, bold=bool(color))
        _w(ws, i, 7, val,  align="center", bg=bg, color=tc, bold=True, size=12)
        ws.merge_cells(start_row=i, start_column=8, end_row=i, end_column=9)
        _w(ws, i, 8, "", border=True)

    # ── TOP 10 ──────────────────────────────────────────────────────────────
    top10 = df.nlargest(10, "opportunity_score").reset_index(drop=True)
    _title_merged(ws, 11, 6, 11, "TOP 10 gmin", _BLUE_MID)
    _header(ws, 12, ["Rank","Gmina","Powiat","Score","Segment","Placówki"],
            bg=_BLUE_MID, height=28)
    for i, row in top10.iterrows():
        r   = 13 + i
        bg  = _ALT if i % 2 else _WHITE
        seg = str(row.get("segment",""))
        sbg, stc = _SEG_STYLE.get(seg, (bg, _BLACK))
        _w(ws, r,  6, int(row["rank"]),                        bg=bg)
        _w(ws, r,  7, str(row.get("gmina","")),                bg=bg, align="left")
        _w(ws, r,  8, str(row.get("powiat","")),               bg=bg, align="left")
        _w(ws, r,  9, row["opportunity_score"],                bg=bg, fmt="0.0")
        _w(ws, r, 10, seg,                                     bg=sbg, color=stc, bold=True)
        _w(ws, r, 11, int(row.get("n_placowek_wlasnych", 0)), bg=bg)

    # ── Dane dla wykresu (kolumna N:O, ukryte) ──────────────────────────────
    ws.cell(row=3, column=14, value="Gmina")
    ws.cell(row=3, column=15, value="Score")
    for i, row in top10.iterrows():
        ws.cell(row=4+i, column=14, value=str(row.get("gmina","")))
        ws.cell(row=4+i, column=15, value=row["opportunity_score"])

    # Bar chart TOP 10
    chart = BarChart()
    chart.type = "bar"; chart.grouping = "clustered"
    chart.title = "Opportunity Score – TOP 10"
    chart.y_axis.title = "Gmina"; chart.x_axis.title = "Score (0–100)"
    chart.style = 10; chart.width = 18; chart.height = 13
    chart.x_axis.numFmt = "0"
    chart.x_axis.scaling.min = 0; chart.x_axis.scaling.max = 100
    dr = Reference(ws, min_col=15, min_row=3, max_row=13)
    cr = Reference(ws, min_col=14, min_row=4, max_row=13)
    chart.add_data(dr, titles_from_data=True)
    chart.set_categories(cr)
    chart.series[0].graphicalProperties.solidFill = "2F5597"
    chart.series[0].dLbls = DataLabelList()
    chart.series[0].dLbls.showVal = True
    chart.series[0].dLbls.numFmt = "0.0"
    ws.add_chart(chart, "F24")

    ws.column_dimensions["A"].width = 24; ws.column_dimensions["B"].width = 10
    ws.column_dimensions["C"].width = 10; ws.column_dimensions["D"].width = 40
    ws.column_dimensions["E"].width = 2
    for col in ["F","G","H","I","J","K"]:
        ws.column_dimensions[col].width = 16
    ws.column_dimensions["L"].width = 2
    ws.column_dimensions["N"].width = 20; ws.column_dimensions["O"].width = 10
    ws.column_dimensions["N"].hidden = True; ws.column_dimensions["O"].hidden = True


