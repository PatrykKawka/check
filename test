# Główna funkcja eksportu
# ─────────────────────────────────────────────────────────────────────────────

def export_dashboard(
    df: pd.DataFrame,
    output_path: str = "scoring_dashboard.xlsx",
    weights: dict | None = None,
) -> str:
    """
    Generuje plik Excel z dashboardem i dynamicznym scoringiem.

    Parameters
    ----------
    df           : DataFrame z run_scoring()
    output_path  : ścieżka wyjściowa
    weights      : wagi — jeśli None, używa DEFAULT_WEIGHTS

    Returns
    -------
    str — ścieżka do zapisanego pliku
    """
    w = weights if weights is not None else DEFAULT_WEIGHTS.copy()

    wb = Workbook()
    print("[1/4] Dashboard...")
    _build_dashboard(wb, df, w)
    print("[2/4] Ranking z formułami Excel...")
    _build_ranking(wb, df)
    print("[3/4] Składowe...")
    _build_skladowe(wb, df)
    print("[4/4] Dane...")
    _build_dane(wb, df)

    wb.save(output_path)
    print(f"\n[OK] {output_path}  |  arkusze: {wb.sheetnames}")
    return output_path
