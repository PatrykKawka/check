def _build_ranking(wb: Workbook, df: pd.DataFrame):
    ws = wb.create_sheet("Ranking")
    ws.sheet_view.showGridLines = False

    # Kolumny statyczne (dane)
    static_cols = [
        (COL_GMINA,               "Gmina",            22, "@"),
        (COL_POWIAT,              "Powiat",            18, "@"),
        ("gmina_jest_powiatem",   "Miasto/powiat",      9, "@"),
        ("n_placowek_wlasnych",   "Placówki",           8, "0"),
        (f"b_{COL_LUDNOSC}",      "Ludność",           12, "#,##0"),
        (f"b_{COL_UDZIAL}",       "Udział klientów",   12, "0.0%"),
        (f"b_{COL_MEDIANA}",      "Mediana wyngr.",    12, "#,##0"),
        (f"b_{COL_PRZYROST}",     "Przyrost nat.",     10, "0.0"),
        (f"b_{COL_MIGRACJA}",     "Saldo migracji",    10, "0.0"),
        (f"b_{COL_OWN}",          "Oddz. własne",       9, "0"),
        (f"b_{COL_COMP}",         "Oddz. konk.",        9, "0"),
        ("c_penetracja_gap",      "Penetracja gap",    12, "0.000"),
        ("c_luka_konkurencyjna",  "Luka konk.",        12, "0.000"),
        ("c_dynamika_wzrostu",    "Dynamika",          12, "0.000"),
        ("c_shift_demograficzny", "Shift dem.",        12, "0.000"),
    ]
    available = [(c, l, w, f) for c, l, w, f in static_cols if c in df.columns]

    # Dodajemy 3 kolumny dynamiczne na końcu
    dyn_headers = ["Score (Excel)", "Segment (Excel)", "Rank (Excel)"]
    all_headers = [l for _, l, _, _ in available] + dyn_headers

    # Tytuł
    total_cols = len(available) + 3
    ws.merge_cells(start_row=1, start_column=1, end_row=1, end_column=total_cols)
    t = ws.cell(row=1, column=1,
                value="Ranking gmin — Score (Excel) przeliczany na bieżąco z wag w Dashboard")
    t.font = _f(True, 12, _WHITE); t.fill = _fill(_NAVY); t.alignment = _al()
    ws.row_dimensions[1].height = 32

    # Nagłówki — dynamiczne kolumny w innym kolorze
    base_fills = [_BLUE_MID] * len(available)
    dyn_fills  = ["1A6B3C"] * 3
    for col, (lbl, bg) in enumerate(zip(all_headers, base_fills + dyn_fills), 1):
        c = ws.cell(row=2, column=col, value=lbl)
        c.font = _f(True, 10, _WHITE); c.fill = _fill(bg)
        c.alignment = _al("center", wrap=True); c.border = _BRD
    ws.row_dimensions[2].height = 36

    # Wyznacz indeksy kolumn składowych (potrzebne do formuły Score Excel)
    comp_excel_cols = {}
    for i, (col, *_) in enumerate(available, start=1):
        for key, cname in _COMP_COL_NAMES.items():
            if col == cname:
                comp_excel_cols[key] = i

    score_col_idx   = len(available) + 1
    segment_col_idx = len(available) + 2
    rank_col_idx    = len(available) + 3
    score_letter    = get_column_letter(score_col_idx)

    df_sorted = df.sort_values("opportunity_score", ascending=False).reset_index(drop=True)
    n_rows    = len(df_sorted)

    for i, (_, row) in enumerate(df_sorted.iterrows()):
        r   = 3 + i
        alt = i % 2 == 1
        bg  = _ALT if alt else _WHITE

        # Dane statyczne
        for j, (col, _, _, fmt) in enumerate(available, start=1):
            val = row.get(col, "")
            if isinstance(val, (np.integer, np.int64)):   val = int(val)
            if isinstance(val, (np.floating, np.float64)): val = float(val)
            cell = ws.cell(row=r, column=j, value=val)
            cell.fill = _fill(bg); cell.font = _f(size=10)
            cell.alignment = _al(); cell.border = _BRD
            cell.number_format = fmt

        # ── Score (Excel) — formuła odwołująca się do wag w Dashboard ──────
        # =( w1*c1 + w2*c2 + w3*c3 + w4*c4 ) / SUMA_WAG  * 100
        parts = []
        for key, cell_addr in _WAGA_CELLS.items():
            ci = comp_excel_cols.get(key)
            if ci:
                parts.append(f"{cell_addr}*{get_column_letter(ci)}{r}")
        if parts:
            formula_score = f"=({'+'.join(parts)})/({_WAGA_SUM})*100"
        else:
            formula_score = row["opportunity_score"]

        cell_s = ws.cell(row=r, column=score_col_idx, value=formula_score)
        cell_s.fill = _fill(bg); cell_s.font = _f(True, 10)
        cell_s.alignment = _al(); cell_s.border = _BRD
        cell_s.number_format = "0.00"

        # ── Segment (Excel) — formuła IFS na Score (Excel) ──────────────────
        sc = f"{score_letter}{r}"
        formula_seg = (
            f'=IFS({sc}>70,"Priorytet",{sc}>50,"Wysoki",'
            f'{sc}>30,"Średni",TRUE,"Niski")'
        )
        cell_sg = ws.cell(row=r, column=segment_col_idx, value=formula_seg)
        cell_sg.fill = _fill(bg); cell_sg.font = _f(True, 10)
        cell_sg.alignment = _al(); cell_sg.border = _BRD

        # ── Rank (Excel) — RANK.EQ odwołujący się do całej kolumny Score ────
        formula_rank = (
            f"=RANK.EQ({sc},"
            f"${score_letter}$3:${score_letter}${2+n_rows},0)"
        )
        cell_rk = ws.cell(row=r, column=rank_col_idx, value=formula_rank)
        cell_rk.fill = _fill(bg); cell_rk.font = _f(True, 10)
        cell_rk.alignment = _al(); cell_rk.border = _BRD
        cell_rk.number_format = "0"

    # Formatowanie warunkowe — color scale na Score (Excel)
    last_r = 2 + n_rows
    ws.conditional_formatting.add(
        f"{score_letter}3:{score_letter}{last_r}",
        ColorScaleRule(
            start_type="min",      start_color="C9453A",
            mid_type="percentile", mid_value=50, mid_color="F4A261",
            end_type="max",        end_color="1A6B3C",
        )
    )

    # Formatowanie warunkowe — kolor segmentu w kolumnie Segment (Excel)
    seg_letter = get_column_letter(segment_col_idx)
    for seg_val, (bg_c, fc) in _SEG_STYLE.items():
        from openpyxl.formatting.rule import CellIsRule
        ws.conditional_formatting.add(
            f"{seg_letter}3:{seg_letter}{last_r}",
            CellIsRule(
                operator="equal",
                formula=[f'"{seg_val}"'],
                fill=_fill(bg_c),
                font=_f(True, 10, fc),
            )
        )

    for j, (_, _, width, _) in enumerate(available, 1):
        ws.column_dimensions[get_column_letter(j)].width = width
    ws.column_dimensions[get_column_letter(score_col_idx)].width   = 14
    ws.column_dimensions[get_column_letter(segment_col_idx)].width = 14
    ws.column_dimensions[get_column_letter(rank_col_idx)].width    = 10

    ws.freeze_panes = "A3"
    ws.auto_filter.ref = f"A2:{get_column_letter(total_cols)}2"




