"""
Bank Branch Opportunity Scoring  —  PLIK FINALNY
=================================================

Dwa moduły w jednym pliku:
  1. run_scoring()      — pipeline analityczny → pd.DataFrame
  2. export_dashboard() — eksport do .xlsx z dynamicznymi wagami

UŻYCIE
------
    import pandas as pd
    from scoring import run_scoring, export_dashboard

    siec  = pd.read_excel("Struktura_sieci.xlsx", dtype={"teryt_gmina": str})
    gminy = pd.read_csv("Dane_o_gminach.csv",
                        dtype={"teryt_gmina": str, "teryt_powiat": str})

    result = run_scoring(siec, gminy)
    export_dashboard(result, "scoring_dashboard.xlsx")

WAGI W EXCELU
-------------
    Arkusz Dashboard, komórki B5:B8 (żółte) — edytowalne bez Pythona.
    Arkusz Ranking zawiera kolumnę „Score (Excel)" wyliczaną formułą:
        =SUMA(waga_penetracja * c_penetracja + ...) / SUMA(wag)
    Zmiana wagi w B5:B8 natychmiast przelicza score i ranking dla wszystkich gmin.

DANE WEJŚCIOWE
--------------
    Struktura_sieci (xlsx):
        gmina, teryt_gmina, powiat
        (każdy wiersz = jedna miejscowość z oddziałem banku)

    Dane_o_gminach (csv):
        teryt_gmina, teryt_powiat, gmina, powiat
        Liczba mieszkańców
        udział klientów w mieszkańcach (%)
        mediana wynagrodzenia brutto
        przyrost naturalny na 1 tys mieszkańców
        saldo migracji na 1 tys. mieszkańców
        różnica między liczbą mieszkańców w wieku 20-35 wg powiatu
        Liczba placówek własnych (moje)
        Liczba placówek własnych konkurencji

LOGIKA BLENDINGU
----------------
    gmina == powiat (miasto na prawach powiatu) → 100 % danych gminnych
    gmina jest częścią powiatu                  → 60 % gmina + 40 % śr. ważona powiatu
    Kolumna różnicy wiekowej (20-35) jest na poziomie powiatu — nie blendowana.

SKŁADOWE SCORINGU  (każda znormalizowana min-max → [0, 1])
----------------------------------------------------------
    penetracja_gap      (domyślna waga 0.35)
        MAX_PENETRATION − aktualny udział klientów
    luka_konkurencyjna  (domyślna waga 0.25)
        1 − własne / (własne + konkurencja)
    dynamika_wzrostu    (domyślna waga 0.25)
        0.6 × saldo_migracji + 0.4 × przyrost_naturalny
    shift_demograficzny (domyślna waga 0.15)
        delta grupy 20-35 wg powiatu (min-max)
"""

import numpy as np
import pandas as pd
import warnings
from openpyxl import Workbook
from openpyxl.chart import BarChart, ScatterChart, Reference, Series
from openpyxl.chart.label import DataLabelList
from openpyxl.formatting.rule import ColorScaleRule
from openpyxl.styles import Alignment, Border, Font, PatternFill, Side
from openpyxl.utils import get_column_letter

warnings.filterwarnings("ignore")


# ══════════════════════════════════════════════════════════════════════════════
# KONFIGURACJA  —  jedyne miejsce wymagające edycji przy zmianie nazw kolumn
# ══════════════════════════════════════════════════════════════════════════════

# Dokładne nazwy kolumn w Dane_o_gminach
COL_TERYT_GMINA  = "teryt_gmina"
COL_TERYT_POWIAT = "teryt_powiat"
COL_GMINA        = "gmina"
COL_POWIAT       = "powiat"

COL_LUDNOSC      = "Liczba mieszkańców"
COL_UDZIAL       = "udział klientów w mieszkańcach (%)"
COL_MEDIANA      = "mediana wynagrodzenia brutto"
COL_PRZYROST     = "przyrost naturalny na 1 tys mieszkańców"
COL_MIGRACJA     = "saldo migracji na 1 tys. mieszkańców"
COL_DELTA_2035   = "różnica między liczbą mieszkańców w wieku 20-35 wg powiatu"
COL_OWN          = "Liczba placówek własnych (moje)"
COL_COMP         = "Liczba placówek własnych konkurencji"

# Parametry modelu
BLEND_GMINA     = 0.60
BLEND_POWIAT    = 0.40
MAX_PENETRATION = 0.35

# Domyślne wagi składowych (suma = 1.0)
DEFAULT_WEIGHTS = {
    "penetracja_gap":      0.35,
    "luka_konkurencyjna":  0.25,
    "dynamika_wzrostu":    0.25,
    "shift_demograficzny": 0.15,
}

# Kolumny blendowane (ważona średnia przez ludność na poziomie powiatu)
_BLEND_COLS = [COL_UDZIAL, COL_MEDIANA, COL_PRZYROST, COL_MIGRACJA]
# Kolumny sumowane na poziomie powiatu
_SUM_COLS   = [COL_LUDNOSC, COL_OWN, COL_COMP]


# ══════════════════════════════════════════════════════════════════════════════
# MODUŁ 1 — PIPELINE SCORINGOWY
# ══════════════════════════════════════════════════════════════════════════════

def run_scoring(
    miejscowosci_df: pd.DataFrame,
    dane_gminy_df: pd.DataFrame,
    weights: dict | None = None,
) -> pd.DataFrame:
    """
    Uruchamia pełny pipeline i zwraca jeden DataFrame z wynikami.

    Returns
    -------
    pd.DataFrame posortowany malejąco według opportunity_score.
    Kolumny: id + b_* (dane po blendingu) + c_* (składowe 0-1) + score/segment/rank.
    """
    w = weights if weights is not None else DEFAULT_WEIGHTS.copy()
    _validate_weights(w)

    siec    = _prepare_network(miejscowosci_df)
    gminy   = _prepare_demographics(dane_gminy_df)
    gminy   = _detect_city_county(gminy)
    pow_agg = _aggregate_powiat(gminy)
    blended = _blend(gminy, pow_agg)

    siec_slim = siec[[COL_TERYT_GMINA, "n_placowek_wlasnych"]]
    result    = blended.merge(siec_slim, on=COL_TERYT_GMINA, how="inner")

    result = _compute_score_components(result)
    result = _compute_composite_score(result, w)

    return result[_build_col_order(result)]\
        .sort_values("opportunity_score", ascending=False)\
        .reset_index(drop=True)


# ─────────────────────────────────────────────────────────────────────────────
# Etap 1 — sieć oddziałów
# ─────────────────────────────────────────────────────────────────────────────

def _prepare_network(df: pd.DataFrame) -> pd.DataFrame:
    d = df.copy()
    d.columns = d.columns.str.strip()
    d = d.rename(columns={
        _find_col(d, ["teryt_gmina", "Teryt_gmina"]): COL_TERYT_GMINA,
        _find_col(d, ["gmina",       "Gmina"]):        COL_GMINA,
        _find_col(d, ["powiat",      "Powiat"]):       COL_POWIAT,
    })
    return (
        d.groupby([COL_TERYT_GMINA, COL_GMINA, COL_POWIAT], as_index=False)
         .size()
         .rename(columns={"size": "n_placowek_wlasnych"})
    )


# ─────────────────────────────────────────────────────────────────────────────
# Etap 2 — normalizacja danych demograficznych
# ─────────────────────────────────────────────────────────────────────────────

def _prepare_demographics(df: pd.DataFrame) -> pd.DataFrame:
    d = df.copy()
    d.columns = d.columns.str.strip()
    if COL_UDZIAL in d.columns and d[COL_UDZIAL].max() > 1:
        d[COL_UDZIAL] = d[COL_UDZIAL] / 100
    return d


# ─────────────────────────────────────────────────────────────────────────────
# Etap 3 — identyfikacja miast na prawach powiatu
# ─────────────────────────────────────────────────────────────────────────────

def _detect_city_county(df: pd.DataFrame) -> pd.DataFrame:
    d = df.copy()
    name_match = (
        d[COL_GMINA].str.lower().str.strip() ==
        d[COL_POWIAT].str.lower().str.strip()
    )
    powiat_cnt  = d.groupby(COL_TERYT_POWIAT)[COL_TERYT_GMINA].transform("count")
    teryt_match = (
        (d[COL_TERYT_GMINA].str[:4] == d[COL_TERYT_POWIAT].str[:4]) &
        (powiat_cnt == 1)
    )
    d["gmina_jest_powiatem"] = name_match | teryt_match
    return d


# ─────────────────────────────────────────────────────────────────────────────
# Etap 4 — agregacja na poziom powiatu
# ─────────────────────────────────────────────────────────────────────────────

def _aggregate_powiat(df: pd.DataFrame) -> pd.DataFrame:
    records = []
    for powiat_id, grp in df.groupby(COL_TERYT_POWIAT):
        rec = {COL_TERYT_POWIAT: powiat_id}
        pop = grp[COL_LUDNOSC].fillna(0) if COL_LUDNOSC in grp.columns \
              else pd.Series(1, index=grp.index)

        for col in _BLEND_COLS:
            if col not in grp.columns:
                continue
            valid = grp[col].notna()
            rec[f"p_{col}"] = (
                np.average(grp.loc[valid, col], weights=pop[valid])
                if valid.any() and pop[valid].sum() > 0
                else grp[col].mean()
            )
        for col in _SUM_COLS:
            if col in grp.columns:
                rec[f"p_{col}"] = grp[col].fillna(0).sum()
        if COL_DELTA_2035 in grp.columns:
            rec[f"p_{COL_DELTA_2035}"] = grp[COL_DELTA_2035].iloc[0]

        records.append(rec)
    return pd.DataFrame(records)


# ─────────────────────────────────────────────────────────────────────────────
# Etap 5 — blending gmina / powiat
# ─────────────────────────────────────────────────────────────────────────────

def _blend(df_gminy: pd.DataFrame, df_pow: pd.DataFrame) -> pd.DataFrame:
    d    = df_gminy.merge(df_pow, on=COL_TERYT_POWIAT, how="left")
    city = d["gmina_jest_powiatem"]

    def blend(col: str) -> pd.Series:
        gm = d[col].fillna(0)
        pw = d[f"p_{col}"].fillna(0) if f"p_{col}" in d.columns else gm
        return pd.Series(
            np.where(city, gm, BLEND_GMINA * gm + BLEND_POWIAT * pw),
            index=d.index
        )

    for col in _BLEND_COLS + _SUM_COLS:
        if col in d.columns:
            d[f"b_{col}"] = blend(col)

    p_delta = f"p_{COL_DELTA_2035}"
    if p_delta in d.columns:
        d[f"b_{COL_DELTA_2035}"] = d[p_delta]

    return d


# ─────────────────────────────────────────────────────────────────────────────
# Etap 6 — składowe scoringu [0, 1]
# ─────────────────────────────────────────────────────────────────────────────

def _compute_score_components(df: pd.DataFrame) -> pd.DataFrame:
    d = df.copy()

    b = lambda col: f"b_{col}"   # skrót

    # 1. Penetracja gap
    if b(COL_UDZIAL) in d.columns:
        gap = (MAX_PENETRATION - d[b(COL_UDZIAL)]).clip(lower=0) / MAX_PENETRATION
        d["c_penetracja_gap"] = _minmax(gap)
    else:
        d["c_penetracja_gap"] = np.nan

    # 2. Luka konkurencyjna
    if b(COL_OWN) in d.columns and b(COL_COMP) in d.columns:
        total = d[b(COL_OWN)].fillna(0) + d[b(COL_COMP)].fillna(0)
        share = np.where(total > 0, d[b(COL_OWN)].fillna(0) / total, 0.5)
        d["c_share_oddzialow"]    = share
        d["c_luka_konkurencyjna"] = _minmax(pd.Series(1 - share, index=d.index))
    else:
        d["c_luka_konkurencyjna"] = np.nan

    # 3. Dynamika wzrostu
    parts = []
    if b(COL_MIGRACJA)  in d.columns: parts.append((d[b(COL_MIGRACJA)].fillna(0),  0.6))
    if b(COL_PRZYROST)  in d.columns: parts.append((d[b(COL_PRZYROST)].fillna(0),  0.4))
    if parts:
        raw = sum(s * w for s, w in parts)
        d["c_dynamika_wzrostu_raw"] = raw
        d["c_dynamika_wzrostu"]     = _minmax(raw)
    else:
        d["c_dynamika_wzrostu"] = np.nan

    # 4. Shift demograficzny
    if b(COL_DELTA_2035) in d.columns:
        d["c_shift_demograficzny"] = _minmax(d[b(COL_DELTA_2035)].fillna(0))
    else:
        d["c_shift_demograficzny"] = np.nan

    return d


# ─────────────────────────────────────────────────────────────────────────────
# Etap 7 — Composite Opportunity Score
# ─────────────────────────────────────────────────────────────────────────────

def _compute_composite_score(df: pd.DataFrame, weights: dict) -> pd.DataFrame:
    d = df.copy()
    comp_map = {
        "penetracja_gap":      "c_penetracja_gap",
        "luka_konkurencyjna":  "c_luka_konkurencyjna",
        "dynamika_wzrostu":    "c_dynamika_wzrostu",
        "shift_demograficzny": "c_shift_demograficzny",
    }
    active  = {k: v for k, v in weights.items()
               if comp_map.get(k) in d.columns and d[comp_map[k]].notna().any()}
    norm_w  = {k: v / sum(active.values()) for k, v in active.items()}

    score = sum(norm_w[k] * d[comp_map[k]].fillna(0) for k in norm_w)
    d["opportunity_score"] = (score * 100).round(2)
    d["segment"] = pd.cut(
        d["opportunity_score"],
        bins=[0, 30, 50, 70, 100],
        labels=["Niski", "Średni", "Wysoki", "Priorytet"],
        include_lowest=True,
    )
    d["rank"] = d["opportunity_score"].rank(ascending=False, method="min").astype(int)
    return d


# ─────────────────────────────────────────────────────────────────────────────
# Helpers pipeline
# ─────────────────────────────────────────────────────────────────────────────

def _minmax(s: pd.Series) -> pd.Series:
    mn, mx = s.min(), s.max()
    return pd.Series(0.5, index=s.index) if mx == mn else (s - mn) / (mx - mn)


def _find_col(df: pd.DataFrame, candidates: list) -> str:
    for c in candidates:
        if c in df.columns:
            return c
    raise KeyError(f"Nie znaleziono kolumny: {candidates}. Dostępne: {list(df.columns)}")


def _validate_weights(w: dict) -> None:
    total = sum(w.values())
    if not np.isclose(total, 1.0, atol=0.01):
        raise ValueError(f"Wagi muszą sumować się do 1.0, aktualnie: {total:.3f}")


def _build_col_order(df: pd.DataFrame) -> list:
    priority = [
        "rank", "opportunity_score", "segment",
        COL_TERYT_GMINA, COL_TERYT_POWIAT, COL_GMINA, COL_POWIAT,
        "gmina_jest_powiatem", "n_placowek_wlasnych",
        f"b_{COL_LUDNOSC}", f"b_{COL_UDZIAL}", f"b_{COL_MEDIANA}",
        f"b_{COL_PRZYROST}", f"b_{COL_MIGRACJA}", f"b_{COL_DELTA_2035}",
        f"b_{COL_OWN}", f"b_{COL_COMP}",
        "c_penetracja_gap", "c_luka_konkurencyjna",
        "c_dynamika_wzrostu_raw", "c_dynamika_wzrostu",
        "c_share_oddzialow", "c_shift_demograficzny",
    ]
    existing  = [c for c in priority if c in df.columns]
    remaining = [c for c in df.columns if c not in existing]
    return existing + remaining


