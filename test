_INPUT    = "0000FF"   # niebieski tekst = komórka edytowalna
_BLACK    = "000000"
_ALT      = "EEF2F7"
_HEAD_BG  = "D6E4F0"
_YELLOW   = "FFF2CC"   # tło żółte = komórka do edycji

_SEG_STYLE = {
    "Priorytet": ("1A6B3C", _WHITE),
    "Wysoki":    ("2E86AB", _WHITE),
    "Średni":    ("F4A261", _BLACK),
    "Niski":     ("C9453A", _WHITE),
}

_THIN   = Side(style="thin",   color="B8C4D0")
_MEDIUM = Side(style="medium", color="4472C4")
_BRD    = Border(left=_THIN, right=_THIN, top=_THIN, bottom=_THIN)


def _f(bold=False, size=10, color=_BLACK, name=_FONT):
    return Font(bold=bold, size=size, color=color, name=name)

def _fill(c):
    return PatternFill("solid", fgColor=c)

def _al(h="center", wrap=False):
    return Alignment(horizontal=h, vertical="center", wrap_text=wrap)

def _w(ws, row, col, val, bold=False, size=10, color=_BLACK,
       bg=None, fmt=None, align="center", wrap=False, border=True):
    cell = ws.cell(row=row, column=col, value=val)
    cell.font      = _f(bold, size, color)
    cell.alignment = _al(align, wrap)
    if bg:    cell.fill   = _fill(bg)
    if fmt:   cell.number_format = fmt
    if border: cell.border = _BRD
    return cell

def _header(ws, row, labels, bg=_NAVY, height=32):
    for col, lbl in enumerate(labels, 1):
        c = ws.cell(row=row, column=col, value=lbl)
        c.font      = _f(True, 10, _WHITE)
        c.fill      = _fill(bg)
        c.alignment = _al("center", wrap=True)
        c.border    = _BRD
    ws.row_dimensions[row].height = height

def _title_merged(ws, row, c1, c2, text, bg=_NAVY, size=11):
    ws.merge_cells(start_row=row, start_column=c1, end_row=row, end_column=c2)
    cell = ws.cell(row=row, column=c1, value=text)
    cell.font      = _f(True, size, _WHITE)
    cell.fill      = _fill(bg)
    cell.alignment = _al("center")
    cell.border    = _BRD
    ws.row_dimensions[row].height = 24


